# SIGEM — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha com os seus valores

NODE_ENV=development
PORT=3000

# Supabase (veja SETUP.md)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="substitua_por_string_aleatoria_de_64_caracteres"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Segurança
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# Frontend
FRONTEND_URL="http://localhost:5173"

# Logs
LOG_LEVEL=debug
